rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helper Functions
    // ─────────────────────────────────────────────────────────

    // Is the requesting user authenticated at all?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Read the user's role from the user_roles collection
    function getUserRole() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role;
    }

    // Is the requesting user a league manager (or legacy admin)?
    function isLeagueManager() {
      return isAuthenticated() && (getUserRole() == 'league_manager' || getUserRole() == 'admin');
    }

    // Is the requesting user a team manager of a specific team?
    function isTeamManagerOf(teamId) {
      return isAuthenticated() && 
        getUserRole() == 'team_manager' && 
        get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.teamId == teamId;
    }

    // Is the requesting user reading/writing their own document?
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────
    // League Data Collections
    // ─────────────────────────────────────────────────────────

    match /teams/{teamId} {
      allow read:  if true;
      // Create: league_manager or team_manager can create
      // Enforce team_manager's team must have approved == false
      // Enforce league_manager can set approved == true
      allow create: if isAuthenticated() && 
        (getUserRole() == 'league_manager' || getUserRole() == 'admin' || getUserRole() == 'team_manager') &&
        ((getUserRole() == 'league_manager' || getUserRole() == 'admin') ? 
          (request.resource.data.approved == true) : 
          (request.resource.data.approved == false));
      // Update: league_manager can update any field including approved
      // team_manager can update their team but NOT the approved field
      allow update: if isLeagueManager() || 
        (isTeamManagerOf(teamId) && resource.data.approved == request.resource.data.approved);
      // Delete: only league manager
      allow delete: if isLeagueManager();
    }

    match /players/{playerId} {
      allow read:  if true;
      // Team managers can add/edit/delete players for their own team
      allow create: if isLeagueManager() || 
                    isTeamManagerOf(request.resource.data.team_id) || 
                    isTeamManagerOf(request.resource.data.teamId);
      allow update: if isLeagueManager() || 
                    ((isTeamManagerOf(resource.data.team_id) || isTeamManagerOf(resource.data.teamId)) && 
                     (isTeamManagerOf(request.resource.data.team_id) || isTeamManagerOf(request.resource.data.teamId)));
      allow delete: if isLeagueManager() || 
                    isTeamManagerOf(resource.data.team_id) || 
                    isTeamManagerOf(resource.data.teamId);
      allow list: if isLeagueManager();
    }

    match /matches/{matchId} {
      allow read:  if true;
      allow write: if isLeagueManager(); // Team managers cannot modify matches
    }

    // ─────────────────────────────────────────────────────────
    // Match Event Collections
    // Only league managers can alter match events
    // ─────────────────────────────────────────────────────────

    match /goals/{goalId} {
      allow read:  if true;
      allow write: if isLeagueManager();
    }

    match /assists/{assistId} {
      allow read:  if true;
      allow write: if isLeagueManager();
    }

    match /yellow_cards/{cardId} {
      allow read:  if true;
      allow write: if isLeagueManager();
    }

    match /red_cards/{cardId} {
      allow read:  if true;
      allow write: if isLeagueManager();
    }

    match /match_attendance/{attendanceId} {
      allow read:  if true;
      allow write: if isLeagueManager();
    }

    // ─────────────────────────────────────────────────────────
    // Suspension Logics (League Manager Only)
    // ─────────────────────────────────────────────────────────

    match /suspensions/{suspensionId} {
      allow read: if isAuthenticated();
      allow write: if isLeagueManager();
    }

    // ─────────────────────────────────────────────────────────
    // PLAYER PROFILE AUTH LINKING
    // ─────────────────────────────────────────────────────────

    match /link_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isLeagueManager();
      allow delete: if isLeagueManager();
    }

    // ─────────────────────────────────────────────────────────
    // User Management Collections
    // ─────────────────────────────────────────────────────────

    // Users can read and update their own profile.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isLeagueManager();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isLeagueManager();
      allow list: if isLeagueManager();
    }

    // user_roles: users can read their own role. League managers can read/write all.
    match /user_roles/{uid} {
      allow read:  if isOwner(uid) || isLeagueManager();
      allow write: if isLeagueManager();
      allow list: if isLeagueManager();
    }

    // user_invites
    match /user_invites/{inviteCode} {
      allow read:   if isAuthenticated();
      allow create: if isLeagueManager();
      allow update: if isAuthenticated();
      allow delete: if isLeagueManager();
    }

    // League Settings
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isLeagueManager();
    }

    // ─────────────────────────────────────────────────────────
    // Catch-all
    // ─────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
